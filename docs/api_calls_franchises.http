@baseUrl = http://localhost:3000
@adminToken = paste-admin-token-here
@franchiseId = paste-franchise-id-here

### Get all franchises
GET {{baseUrl}}/api/franchises

### Get franchise by id
GET {{baseUrl}}/api/franchises/{{franchiseId}}

### Create franchise - admin only
POST {{baseUrl}}/api/franchises
x-auth-token: {{adminToken}}
Content-Type: application/json

{
  "name": "Pokemon",
  "createdBy": "Game Freak",
  "firstReleaseYear": 1996,
  "description": ""
}

### Update franchise - admin only
PUT {{baseUrl}}/api/franchises/{{franchiseId}}
x-auth-token: {{adminToken}}
Content-Type: application/json

{
  "name": "Pokemon",
  "createdBy": "Game Freak",
  "firstReleaseYear": 1996,
  "description": "Monster collecting RPG franchise."
}

### Delete franchise - admin only
DELETE {{baseUrl}}/api/franchises/{{franchiseId}}
x-auth-token: {{adminToken}}

### Expected to fail - create franchise without token
POST {{baseUrl}}/api/franchises
Content-Type: application/json

{
  "name": "Pokemon",
  "createdBy": "Game Freak",
  "firstReleaseYear": 1996,
  "description": ""
}

### Expected to fail - create franchise with invalid data
POST {{baseUrl}}/api/franchises
x-auth-token: {{adminToken}}
Content-Type: application/json

{
  "name": "P",
  "createdBy": "",
  "firstReleaseYear": 1940,
  "description": ""
}

### Expected to fail - get franchise with invalid id
GET {{baseUrl}}/api/franchises/not-a-valid-id
