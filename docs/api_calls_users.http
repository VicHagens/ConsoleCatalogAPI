@baseUrl = http://localhost:3000
@token = paste-user-token-here
@adminToken = paste-admin-token-here
@userId = paste-user-id-here

### Get current user
GET {{baseUrl}}/api/users/me
x-auth-token: {{token}}

### Get all users - admin only
GET {{baseUrl}}/api/users
x-auth-token: {{adminToken}}

### Get user by id - admin only
GET {{baseUrl}}/api/users/{{userId}}
x-auth-token: {{adminToken}}

### Update own profile
PUT {{baseUrl}}/api/users/{{userId}}
x-auth-token: {{token}}
Content-Type: application/json

{
  "name": "Vic Updated",
  "email": "vic.updated@example.com"
}

### Update user as admin
PUT {{baseUrl}}/api/users/{{userId}}
x-auth-token: {{adminToken}}
Content-Type: application/json

{
  "name": "Vic Admin Updated",
  "email": "vic.admin.updated@example.com",
  "role": "admin"
}

### Delete user - admin only
DELETE {{baseUrl}}/api/users/{{userId}}
x-auth-token: {{adminToken}}

### Expected to fail - get all users without token
GET {{baseUrl}}/api/users

### Expected to fail - get all users as normal user
GET {{baseUrl}}/api/users
x-auth-token: {{token}}

### Expected to fail - get user with invalid id
GET {{baseUrl}}/api/users/not-a-valid-id
x-auth-token: {{adminToken}}

### Expected to fail - user tries to update own role
PUT {{baseUrl}}/api/users/{{userId}}
x-auth-token: {{token}}
Content-Type: application/json

{
  "name": "Vic Updated",
  "email": "vic.updated@example.com",
  "role": "admin"
}
