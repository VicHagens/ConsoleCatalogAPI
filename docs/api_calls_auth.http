@baseUrl = http://localhost:3000

### Register user
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "Vic",
  "email": "vic@example.com",
  "password": "password123"
}

### Login user
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "vic@example.com",
  "password": "password123"
}
